# متغيرات البيئة لبوت التليجرام وتحديثات GitHub

# توكن بوت التليجرام
# الحصول عليه من: https://t.me/BotFather
# أرسل الأمر /newbot واتبع الخطوات
TELEGRAM_TOKEN=اكتب_توكن_البوت_هنا

# آيدي الدردشة (Chat ID) الخاص بك
# الحصول عليه من: https://t.me/userinfobot
# أرسل /start واحصل على الـ ID الخاص بك
CHAT_ID=اكتب_آيدي_حسابك_في_تليجرام_هنا

# منفذ التطبيق (اختياري - القيمة الافتراضية 5000)
# PORT=5000

# ملاحظات هامة:
# - تأكد من عدم مشاركة هذا الملف مع أحد
# - أضف .env إلى ملف .gitignore لحماية بيانات حسابك
# - عند نشر التطبيق على خادم، استخدم متغيرات البيئة في إعدادات الاستضافة
